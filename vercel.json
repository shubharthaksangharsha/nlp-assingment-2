{
  "version": 2,
  "builds": [
    {
      "src": "web-app/app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "web-app/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/web-app/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web-app/app.py"
    }
  ]
} 